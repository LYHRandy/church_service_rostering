# Copy to supabase/.env.local for `supabase functions serve` — never commit the real file.

# Telegram bot token from @BotFather (use the DEV bot locally, not production)
TELEGRAM_BOT_TOKEN=

# Random secret registered with setWebhook (secret_token) and validated by the webhook handler
TELEGRAM_WEBHOOK_SECRET=

# LOCAL ONLY (leave unset in production): getMe result as JSON so a fake token works offline
# TELEGRAM_BOT_INFO={"id":1,"is_bot":true,"first_name":"DevBot","username":"dev_bot","can_join_groups":true,"can_read_all_group_messages":false,"supports_inline_queries":false,"can_connect_to_business":false,"has_main_web_app":false}

# Church timezone for message formatting (default Asia/Singapore)
# CHURCH_TZ=Asia/Singapore
